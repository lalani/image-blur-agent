# =========================================================================
# Anonymizer AI - Environment Configuration Example
# Copy this file to a new file named `.env` and fill in your keys.
# =========================================================================

# --- Google Gemini API Credentials ---
# Get a free API key from Google AI Studio: https://aistudio.google.com/
# If provided, the backend will automatically fallback to local Google AI Studio
# calls instead of requiring Google Cloud Vertex AI / ADC authentication.
GOOGLE_API_KEY=your_google_ai_studio_key_here

# --- Optional FastAPI Configurations ---
# List of allowed CORS origins separated by commas (defaults to Vite dev server ports)
# ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
